        { "src": "images/master-tattoo-3.png", "alt": "Tatto Master page 3", "caption": "Page 3 — Barak, Catacomb Master 2 & 3, Foundation Oath and more" },
        { "src": "images/master-tattoo-4.png", "alt": "Tatto Master page 4", "caption": "Page 4 — Sage's Ward, Vanguard Stance, Archmage's Focus and more" },
        { "src": "images/master-tattoo-5.png", "alt": "Tatto Master page 5", "caption": "Page 5 — Bunny" }
      ]
